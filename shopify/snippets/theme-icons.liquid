{% # theme-check-disable %}
{%- comment -%}
  -------------------------------------------------------------------------------
  Theme Icons
  -------------------------------------------------------------------------------
  Accepts
  - class: {String} Additional class name (optional)
  - styling: {String} Style attribute, useful for color settings (optional)
  - highlight_icon: {Boolean} applies the global highlight color to the icon
  - width: {Integer} (optional)
  - height: {Integer} (optional)
  -------------------------------------------------------------------------------
  Usage
  {%- render 'theme-icons',
    icon: 'icon',
    classes: 'classes',
    styling: 'styling',
    highlight_icon: highlight_icon,
    width: 16,
    height: 16,
  -%}
  -------------------------------------------------------------------------------
  Description
  Renders a icon
{%- endcomment -%}

{%- liquid
  assign styling = styling
  assign highlight_icon = highlight_icon
  assign classes = classes
  assign stroke = stroke | default: "currentColor"
  assign fill = fill | default: "none"

  if highlight_icon
    assign classes = classes | append: ' fill-highlight stroke-highlight'
  endif

  assign theme-icons = theme-icons | downcase
-%}

{%- capture default_svg_open_tag -%}
  <svg
    class="{{ classes }}"
    style="{{ styling }}"
    focusable="false"
    viewBox="0 0 {{ viewBox_w | default: '24' }} {{ viewBox_h | default: '24' }} "
    xmlns="http://www.w3.org/2000/svg"
    stroke="{{ stroke }}"
    fill="{{ fill }}"
    width="{{ width | default: 24 }}"
    height="{{ height | default: 24 }}"
  >
{%- endcapture -%}

