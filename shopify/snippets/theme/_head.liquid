{%- liquid
  assign header_font = settings.type_header_font
  assign body_font = settings.type_body_font

  assign header_font_fallback = settings.type_header_font_fallback
  assign body_font_fallback = settings.type_body_font_fallback
-%}

<link rel="preload" href="{{ header_font | font_url: 'woff2' }}" as="font" type="font/woff2" crossorigin>
{%- if body_font.family != header_font.family and body_font.weight != header_font.weight -%}
  <link rel="preload" href="{{ body_font | font_url: 'woff2' }}" as="font" type="font/woff2" crossorigin>
{%- endif -%}

{% if collection.handle contains 'test' %}
  <meta name="robots" content="noindex">
{% endif %}

{% # prettier-ignore %}
<script>
  Shopify.moneyFormat = {{ shop.money_format | json }};
  Shopify.routes = {
    ...Shopify.routes,
    cartUrl: {{ routes.cart_url | json }},
    cartAddUrl: {{ routes.cart_add_url | json }},
    cartChangeUrl: {{ routes.cart_change_url | json }},
    cartUpdateUrl: {{ routes.cart_update_url | json }},
    predictiveSearchUrl: {{ routes.predictive_search_url | json }},
  }
  Shopify.theme.i18n = {
    addToCart: `{{ 'products.product.add_to_cart' | t }}`,
    soldOut: `{{ 'products.product.sold_out' | t }}`,
    unavailable: `{{ 'products.product.unavailable' | t }}`,
    cart: {
      error: `{{ 'sections.cart.cart_error' | t }}`,
      quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`,
    },
    shareSuccess: `{{ 'general.share.success_message' | t }}`,
    global: {
      dialogs: {
        accessibility: {
          actions: {
          open: {{ 'global.dialogs.accessibility.actions.open' | t | json }},
            close: {{ 'global.dialogs.accessibility.actions.close' | t | json }}
          }
        }
      }
    }
  };
</script>

{%- style -%}
  {% if settings.use_custom_font %}
    @font-face {
      font-family: 'Larken';
      src: url({{ 'Larken-Thin.woff2' | asset_url }}) format('woff2'),
          url({{ 'Larken-Thin.woff' | asset_url }}) format('woff');
      font-weight: 100;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: 'Larken';
      src: url({{ 'Larken-Light.woff2' | asset_url }}) format('woff2'),
          url({{ 'Larken-Light.woff' | asset_url }}) format('woff');
      font-weight: 300;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: 'Larken';
      src: url({{ 'Larken-Regular.woff2' | asset_url }}) format('woff2'),
          url({{ 'Larken-Regular.woff' | asset_url }}) format('woff');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: 'Larken';
      src: url({{ 'Larken-Medium.woff2' | asset_url }}) format('woff2'),
          url({{ 'Larken-Medium.woff' | asset_url }}) format('woff');
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: 'Larken';
      src: url({{ 'Larken-Bold.woff2' | asset_url }}) format('woff2'),
          url({{ 'Larken-Bold.woff' | asset_url }}) format('woff');
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: 'Larken';
      src: url({{ 'Larken-ThinItalic.woff2' | asset_url }}) format('woff2'),
          url({{ 'Larken-ThinItalic.woff' | asset_url }}) format('woff');
      font-weight: 100;
      font-style: italic;
      font-display: swap;
    }

    @font-face {
      font-family: 'Larken';
      src: url({{ 'Larken-LightItalic.woff2' | asset_url }}) format('woff2'),
          url({{ 'Larken-LightItalic.woff' | asset_url }}) format('woff');
      font-weight: 300;
      font-style: italic;
      font-display: swap;
    }

    @font-face {
      font-family: 'Larken';
      src: url({{ 'Larken-Italic.woff2' | asset_url }}) format('woff2'),
          url({{ 'Larken-Italic.woff' | asset_url }}) format('woff');
      font-weight: 400;
      font-style: italic;
      font-display: swap;
    }

    @font-face {
      font-family: 'Larken';
      src: url({{ 'Larken-MediumItalic.woff2' | asset_url }}) format('woff2'),
          url({{ 'Larken-MediumItalic.woff' | asset_url }}) format('woff');
      font-weight: 500;
      font-style: italic;
      font-display: swap;
    }

    @font-face {
      font-family: 'Larken';
      src: url({{ 'Larken-BoldItalic.woff2' | asset_url }}) format('woff2'),
          url({{ 'Larken-BoldItalic.woff' | asset_url }}) format('woff');
      font-weight: 700;
      font-style: italic;
      font-display: swap;
    }
  {% else %}
    {% for font in header_font.variants %}
      {{ font | font_face: font_display: 'swap' }}
    {% endfor %}

    {% if body_font.family != header_font.family %}
      {% for font in body_font.variants %}
        {{ font | font_face: font_display: 'swap' }}
      {% endfor %}
    {% endif %}
  {% endif %}

  {% for font in header_font_fallback.variants %}
    {{ font | font_face: font_display: 'swap' }}
  {% endfor %}

  {% if body_font_fallback.family != header_font_fallback.family %}
    {% for font in body_font.variants %}
      {{ font | font_face: font_display: 'swap' }}
    {% endfor %}
  {% endif %}

  :root {
    /* Layout */
    --base-space: 24px;
    --page-width: 1432;
    --page-space: clamp(var(--base-space), 8.21vw + -1rem, 12.8rem);
    --gap: clamp(2.4rem, 1.26vw + 1.88rem, 4rem);

    /* Typography */
    {%- liquid
      assign font_header = header_font.family

      if settings.use_custom_font
        assign font_header = 'Larken'
      endif
