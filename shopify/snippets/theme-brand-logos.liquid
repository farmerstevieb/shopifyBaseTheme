{%- comment -%}
  -------------------------------------------------------------------------------
  Theme Brand Logos
  -------------------------------------------------------------------------------
  Accepts
  - section: {Object} (required)
  - class: {String} Additional class name (optional)
  - styling: {String} Style attribute, useful for color settings (optional)
  - width: {Integer} (optional)
  - height: {Integer} (optional)
  -------------------------------------------------------------------------------
  Usage
  {%- render 'theme-brand-logos',
    section: section,
    classes: 'classes',
    styling: 'styling',
    width: 16,
    height: 16,
  -%}
  -------------------------------------------------------------------------------
  Description
  Renders a patchworks brand logo.
{%- endcomment -%}

{%- liquid
  assign classes = classes
  assign styling = styling

  assign theme-brand-logos = theme-brand-logos | downcase

  assign logo_colour = logo_colour | default: section.settings.logo_colour
  assign word_one_colour = word_one_colour | default: section.settings.word_one_colour
  assign word_two_colour = word_two_colour | default: section.settings.word_two_colour
-%}

