{%- assign text_class = 'text-sm font-semibold tracking-standard text-grey-10 uppercase' -%}
<drawer-cart class="dialog js-drawer-cart" id="DrawerCart" modal-mode="side" hidden>
  <div data-a11y-dialog-hide></div>

  <div role="document">
    <div data-dialog-element="header">
      <div class="flex gap-x-1 items-center">
        <h2 class="{{ text_class }}">{{ 'sections.drawer_cart.title' | t }}</h2>
        <span class="text-xs text-secondary">
          <span class="js-cart-item-count">{{ cart.item_count }}</span> {{ 'sections.drawer_cart.items' | t -}}
        </span>
      </div>

      <button data-dialog-element="close" is="modal-opener" modal="#DrawerCart">
        {%- render 'theme-icons' with 'close' -%}
        <span class="sr-only">{{ 'sections.drawer_cart.close_dialog' | t -}}</span>
      </button>

      {%- if settings.free_delivery_enabled -%}
        <label class="delivery-progress text-smd text-grey-5 flex flex-col mt-2">
          {%- liquid
            assign remaining = localization.market.metafields.custom.delivery_threshold | minus: cart.total_price
            if remaining > 0
              assign remaining_money = remaining | money
              assign label = 'general.free_delivery.in_progress_html' | t: money: remaining_money
            else
              assign label = 'general.free_delivery.completed' | t
            endif
          -%}
          <span class="mb-2">{{ label }}</span>
          <progress
            max="{{ localization.market.metafields.custom.delivery_threshold }}"
            value="{{ cart.total_price }}"
          ></progress>
        </label>
      {%- endif -%}
    </div>

    <div data-dialog-element="main" class="flex-grow">
      {%- if cart == empty -%}
        <div class="h-full w-full grid place-content-center text-center">
          <h2 class="{{ text_class }} mb-2">{{ 'sections.cart.empty' | t }}</h2>

          <a
            is="modal-opener"
            href="{{ routes.all_products_collection_url }}"
            modal="#DrawerCart"
            class="button button--primary min-w-[180px]"
          >
            {{ 'general.continue_shopping' | t }}
          </a>

          {%- if shop.customer_accounts_enabled and customer == null -%}
            <p class="font-bold mt-8">{{ 'sections.cart.login.title' | t }}</p>
            <p class="rte text-md">
              {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
            </p>
          {%- endif -%}
        </div>
      {%- endif -%}

      <drawer-cart-items
        {%- if cart == empty %}
          hidden
        {%- endif -%}
      >
        <form
          action="{{ routes.cart_url }}"
          id="DrawerCart-Form"
          method="post"
        >
          <div id="DrawerCart-CartItems">
            {%- if cart != empty -%}
              <table role="table" class="w-full">
                <thead role="rowgroup">
                  <tr role="row">
                    <th id="DrawerCart-ColumnProductImage" role="columnheader">
                      <span class="sr-only">{{ 'sections.cart.headings.image' | t }}</span>
                    </th>
                    <th id="DrawerCart-ColumnProduct" scope="col" role="columnheader">
                      <span class="sr-only">{{ 'sections.cart.headings.product' | t }}</span>
                    </th>
                    <th id="DrawerCart-ColumnTotal" scope="col" role="columnheader">
                      <span class="sr-only">{{ 'sections.cart.headings.total' | t }}</span>
                    </th>
                    <th id="DrawerCart-ColumnQuantity" role="columnheader">
                      <span class="sr-only">{{ 'sections.cart.headings.quantity' | t }}</span>
                    </th>
                    <th id="DrawerCart-ColumnRemove" role="columnheader">
                      <span class="sr-only">{{ 'sections.cart.headings.remove' | t }}</span>
                    </th>
                  </tr>
                </thead>

                <tbody role="rowgroup">
                  {%- for item in cart.items -%}
                    <tr
                      id="DrawerCart-Item-{{ item.index | plus: 1 }}"
                      class="cart-item cart-item--drawer mb-6 pb-6"
                      role="row"
                    >
                      <td class="cart-item__media relative" role="cell" headers="DrawerCart-ColumnProductImage">
                        {%- if item.image -%}
                          <a href="{{ item.url }}" class="absolute inset-0" tabindex="-1" aria-hidden="true"> </a>
                          <img
                            src="{{ item.image | image_url: width: 128 }}"
                            alt="{{ item.image.alt | escape }}"
                            loading="lazy"
                            width="64"
                            height="82"
                            class="aspect-[64/82]"
                          >
                        {%- endif -%}
                      </td>

                      <td class="cart-item__details text-md" role="cell" headers="DrawerCart-ColumnProduct">
                        <a href="{{ item.url }}" class="{{ text_class }} cart-item__name">
                          {{- item.product.title | escape -}}
                        </a>

                        {% # Check if item is pre-order and show label %}
                        {%- liquid
                          assign is_preorder = false
                          assign variant = item.product.selected_or_first_available_variant

                          # Check Stoq metafields for pre-order setup
                          # Primary check: selling_plan_ids indicates pre-order is configured
                          if variant.metafields.restockrocket_production.selling_plan_ids != blank
                            assign is_preorder = true
                          endif

                          # Secondary check: preorder_enabled metafield (if available)
                          if variant.metafields.restockrocket_production.preorder_enabled.value == true
                            assign is_preorder = true
                          endif



                          # Check if pre-order is full
                          assign is_preorder_full = false
                          assign preorder_count = variant.metafields.restockrocket_production.preorder_count.value | default: 0
                          assign preorder_max = variant.metafields.restockrocket_production.preorder_max_count.value
                          if preorder_max
                            assign spots_remaining = preorder_max | minus: preorder_count
                            if spots_remaining <= 0
                              assign is_preorder_full = true
                            endif
                          endif
                        -%}



                        {%- if item.product.has_only_default_variant == false or item.properties.size != 0 -%}
                          <dl class="text-grey-40 text-smd">
                            {%- if item.product.has_only_default_variant == false -%}
                              {%- for option in item.options_with_values -%}
                                <dt class="sr-only">{{ option.name }}:</dt>
                                <dd class="inline">
                                  {{ option.value -}}
                                  {%- unless forloop.last %}
                                    <span aria-hidden="true">/</span>
                                  {% endunless %}
                                </dd>
                              {%- endfor -%}
                            {%- endif -%}

                            {%- for property in item.properties -%}
                              {%- assign property_first_char = property.first | slice: 0 -%}
                              {%- if property.last != blank and property_first_char != '_' -%}
                                <div>
                                  <dt class="inline">{{ property.first }}:</dt>
                                  <dd class="inline">{{ property.last }}</dd>
                                </div>
                              {%- endif -%}
                            {%- endfor -%}
                          </dl>
                        {%- endif -%}

                        {%- if item.selling_plan_allocation != null -%}
                          <p>{{ item.selling_plan_allocation.selling_plan.name }}</p>
                        {%- endif -%}

                        <ul class="text-secondary" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                          {%- for discount in item.discounts -%}
                            <li class="flex gap-x-1 items-center">
                              {%- render 'theme-icons' with 'discount' -%}
                              {{ discount.title }}
                            </li>
                          {%- endfor -%}
                        </ul>

                        <div
                          class="flex gap-x-1 items-center mt-2"
                          id="DrawerCart-LineItemError-{{ item.index | plus: 1 }}"
                          role="alert"
                        >
                          <span class="order-1 peer"></span>
                          <span class="inline-flex peer-empty:hidden flex-shrink-0">
                            {%- render 'theme-icons' with 'error', width: 12, height: 12 -%}
                          </span>
                        </div>
                      </td>

                      <td
                        class="cart-item__totals relative flex items-center justify-end"
                        role="cell"
                        headers="DrawerCart-ColumnTotal"
                      >
                        <div class="loading-overlay hidden">
                          <div class="loading-overlay__spinner">
                            {%- render 'theme-icons' with 'loading' -%}
                          </div>
                        </div>

                        <div class="flex flex-col gap-y-1 text-sm leading-none text-grey-10">
                          {%- if item.original_line_price != item.final_line_price -%}
                            <span class="sr-only">{{ 'products.product.price.regular_price' | t }}</span>
                            <s class="text-secondary">{{ item.original_line_price | money }}</s>
                            <span class="sr-only">{{ 'products.product.price.sale_price' | t }}</span>
                            <span class="font-semibold">{{ item.final_line_price | money }}</span>
                          {%- else -%}
                            <span class="font-semibold">{{ item.original_line_price | money }}</span>
                          {%- endif -%}
                        </div>
                      </td>

                      <td class="cart-item__quantity flex justify-end" role="cell" headers="DrawerCart-ColumnQuantity">
                        <quantity-input class="quantity-input quantity-input--small js-quantity-input">
                          <button class="button" name="minus">
                            <span class="sr-only">
                              {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
                            </span>
                            {%- render 'theme-icons' with 'minus', width: 16, height: 16 -%}
                          </button>
                          <input
                            id="Drawer-quantity-{{ item.index | plus: 1 }}"
                            type="number"
                            class="font-semibold"
                            data-quantity-variant-id="{{ item.variant.id }}"
                            name="updates[]"
                            value="{{ item.quantity }}"
                            data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                            min="{{ item.variant.quantity_rule.min }}"
                            {% if item.variant.quantity_rule.max != null %}
                              max="{{ item.variant.quantity_rule.max }}"
                            {% endif %}
                            step="{{ item.variant.quantity_rule.increment }}"
                            aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                            data-index="{{ item.index | plus: 1 }}"
                          >
                          <button class="button" name="plus">
                            <span class="sr-only">
                              {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
                            </span>
                            {%- render 'theme-icons' with 'plus', width: 16, height: 16 -%}
                          </button>
                        </quantity-input>
                      </td>

                      <td
                        class="cart-item__remove inline-flex justify-end"
                        role="cell"
                        headers="DrawerCart-ColumnRemove"
                      >
                        <button
                          is="remove-cart-item"
                          id="DrawerCart-Remove-{{ item.index | plus: 1 }}"
                          data-index="{{ item.index | plus: 1 }}"
                          class="button button--underline text-sm text-grey-0"
                          aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
                        >
                          Remove
                        </button>
                      </td>
                    </tr>
                  {%- endfor -%}
                </tbody>
              </table>
            {%- endif -%}

            <p id="DrawerCart-LiveRegionText" class="sr-only" role="status"></p>
            <p id="DrawerCart-LineItemStatus" class="sr-only" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div class="text-validation-error text-md mb-5 empty:hidden" id="DrawerCart-CartErrors" role="alert"></div>
        </form>
      </drawer-cart-items>

      <div
        {%- if cart == empty %}
          hidden
        {%- endif -%}
      >
        <div class="flex flex-col gap-y-2 text-smd text-grey-0 py-6 border-b border-grey-95">
          {%- assign summary_title = 'text-smd font-normal tracking-0 capitalize' -%}
          <div class="flex flex-wrap gap-y-1 justify-between" role="status">
            <h2 class="{{ summary_title }}">{{ 'sections.cart.subtotal' | t }}</h2>
            <p class="font-semibold">{{ cart.total_price | money }}</p>

            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <ul
                class="flex flex-col items-end w-full text-sm text-grey-20"
                role="list"
                aria-label="{{ 'customer.order.discount' | t }}"
              >
                {%- for discount in cart.cart_level_discount_applications -%}
                  <li class="flex gap-x-1">
                    {%- render 'theme-icons' with 'discount' -%}
                    {{ discount.title }}
                    (-{{ discount.total_allocated_amount | money }})
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          {% assign tax = 'Calculated at checkout' %}
          {% assign shipping = 'Calculated at checkout' %}
          {%- if cart.taxes_included -%}
            {% assign tax = 'Included' %}
          {%- endif -%}

          <div class="flex justify-between">
            <h2 class="{{ summary_title }}">{{ 'sections.cart.headings.shipping' | t }}</h2>
            <p>{{ shipping }}</p>
          </div>

          <div class="flex justify-between">
            <h2 class="{{ summary_title }}">{{ 'sections.cart.headings.tax' | t }}</h2>
            <p>{{ tax }}</p>
          </div>
        </div>

        {%- if settings.estimate_delivery_enabled -%}
          <delivery-countdown
            class="flex items-center gap-x-rem text-smd text-grey-10 py-6"
            cutoff="{{ settings.estimate_delivery_cutoff }}"
            excludedDates="{{ settings.estimate_delivery_excluded_dates }}"
            nextdaylabel="{{ 'general.delivery_estimate.nextday_delivery_html' | t: time: '[time]', date: '[date]' }}"
            nextweeklabel="{{ 'general.delivery_estimate.weekday_delivery_html' | t: day: '[day]' }}"
          >
            <svg width="20" height="20" fill="currentcolor" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
              <path d="M10 1.667c-4.596 0-8.334 3.738-8.334 8.333 0 4.595 3.738 8.333 8.333 8.333 4.595 0 8.334-3.738 8.334-8.333 0-4.595-3.739-8.333-8.334-8.333Zm0 15A6.674 6.674 0 0 1 3.332 10a6.674 6.674 0 0 1 6.666-6.667A6.674 6.674 0 0 1 16.666 10a6.674 6.674 0 0 1-6.667 6.667Z" />
              <path d="M10.833 5.833H9.166v4.512l2.744 2.744 1.178-1.178-2.255-2.256V5.833Z" />
            </svg>
            <p class="invisible b:font-semibod">
              {{ 'general.delivery_estimate.nextday_delivery_html' | t: time: '[time]', date: '[date]' }}
            </p>
          </delivery-countdown>
        {%- endif %}

        <button
          type="submit"
          id="DrawerCart-Checkout"
          class="button button--primary button--full"
          form="DrawerCart-Form"
          {% if cart == empty %}
            disabled
          {% endif %}
        >
          {{ 'sections.cart.checkout' | t }}
        </button>
      </div>
    </div>
    {% if cart != empty %}
      <div class="js-drawer-cart-recommendations">
        <product-recommendations
          id="DrawerCart-Recomendations"
          data-url="{{ routes.product_recommendations_url }}?section_id=cart-drawer-related-products&product_id={{ cart.items.first.product_id }}&limit={{ 3 | plus: cart.items.size | at_most: 10 }}&intent=related"
        >
        </product-recommendations>
      </div>
    {% endif %}
  </div>
</drawer-cart>
