{%- comment -%}
  -------------------------------------------------------------------------------
  CTAs
  -------------------------------------------------------------------------------
  Accepts
  - settings: {Object} (required) the section or block settings
  - cta_sizes: {String} (optional) alter the size of the ctas
  - class: {String} (optional) add a custom class
  - amount: {Integer} (optional) generate more than a single button. The index
    generated by amount will correspond to the cta(index: value) set inside
    of the schema.
  - starting_index: {Integer} (optional) generally used to skip a iteration
    in the cta forloop. So if you have two cta settings inside of the schema,
    but you don't want them generated side by side? You would split it into
    two renders, and have the second cta render with the starting_index being
    set to 2, and the amount set to 2.
  - external_button: {Object} (option) insert content from outside of the
    render
  -------------------------------------------------------------------------------
  Usage
  {%- render 'object-ctas' with
    settings: settings,
    amount: amount
    cta_sizes: 'size',
    class: 'class',
    amount: amount,
    starting_index: starting_index,
    external_button: external_button
  -%}
  -------------------------------------------------------------------------------
  Description
  Displays one or two CTA buttons, with the option to add custom icons. For
  use specifically with the ...cta() part utilised in schema files.
{%- endcomment -%}

{%- liquid
  assign amount = amount | default: 1
  assign starting_index = starting_index | default: 1
  assign cta_custom_class = cta_custom_class | default: ''

  comment
    Applies default flex-direction classes, unless the optional class setting
    contains a flex-direction class, in which case these are removed.
  endcomment
  assign class = class
  assign default_classes = 'o-ctas--default'
  assign cta_link = cta_link

  if class contains 'flex-col' or class contains 'flex-row'
    assign default_classes = ''
  elsif cta_sizes == 'full'
    assign default_classes = 'o-ctas--full'
  endif

  assign classes = default_classes | append: ' ' | append: class

  # Controls button sizing: smallest, small, medium

  assign cta_sizes = cta_sizes | default: settings.cta_sizes | default: 'full'
  assign cta_sizes_dsk = cta_sizes_dsk | default: settings.cta_sizes_dsk | default: 'medium'

  capture button_size_mob
    case cta_sizes
      when 'small'
        echo ' max-lg:button--small'
      when 'standard'
        echo ' max-lg:button--standard'
      when 'medium'
        echo ' max-lg:button--medium'
      when 'large'
        echo ' max-lg:button--large'
      when 'full'
        echo ' max-lg:button--full'
    endcase
  endcapture

  capture button_size_dsk
    case cta_sizes_dsk
      when 'small'
        echo ' lg:button--small'
      when 'standard'
        echo ' lg:button--standard '
      when 'medium'
        echo ' lg:button--medium'
      when 'large'
        echo ' lg:button--large'
      when 'full'
        echo ' lg:button--full'
    endcase
  endcapture

  # Look for available CTA Content
  assign has_ctas = false

  for cta in (starting_index..amount)
    assign index = forloop.index0 | plus: starting_index
    assign text_setting = 'cta_' | append: index | append: '_text'

    if settings[text_setting] != blank
      assign has_ctas = true
    endif
  endfor

  # External Content
  # - Content inserted directly from inside the theme,
  # - helps maintain the structure of elements.
  assign external_button = external_button | default: ''
-%}

{%- if has_ctas -%}
  <div class="o-ctas inline-flex gap-1 {{ classes }} {{ cta_custom_class }}">
    {%- for cta in (starting_index..amount) -%}
      {%- liquid
        assign index = forloop.index0 | plus: starting_index

        assign text_setting = 'cta_' | append: index | append: '_text'
        assign link_style_setting = 'cta_' | append: index | append: '_link_style'
        assign link_setting = 'cta_' | append: index | append: '_link'
        assign target_setting = 'cta_' | append: index | append: '_target'
        assign icon_setting = 'cta_' | append: index | append: '_icon'
        assign icon_position_setting = 'cta_' | append: index | append: '_icon_position'
      -%}

      {%- if settings[text_setting] != blank -%}
        {%- liquid
          capture cta_style
            unless settings[link_style_setting] == 'link'
              echo 'button button--remove-icon button--' | append: settings[link_style_setting] | append: button_size_mob | append: button_size_dsk
            else
              echo 'link'
            endunless
          endcapture
        -%}

        <a
          class="{{ cta_style }} o-ctas__cta o-ctas__cta--{{ forloop.index }} flex gap-4 font-medium text-sm"
          {% if settings[link_setting] != blank or cta_link != blank %}
            href="{%- if cta_link != blank -%}{{cta_link}}{%- else -%}{{ settings[link_setting] }}{%- endif -%}"
          {% else %}
            role="link" aria-disabled="true"
          {% endif %}
          {% if settings[target_setting] %}
            rel="noreferrer"
            target="_blank"
          {% endif %}
        >
          {%- if settings[link_style_setting] == 'link'
            and settings[icon_setting] != 'none'
            and settings[icon_position_setting] == 'left'
          -%}
            <div
              class="min-w-[18px] rounded-full flex items-center justify-center min-h-[18px] aspect-square o-ctas__cta-icon"
            >
          {%- endif -%}
          {%- liquid
            if settings[icon_setting] != 'none' and settings[icon_position_setting] == 'left'
              render 'theme-icons' with settings[icon_setting], width: '1.5em', height: '1.5em'
            endif
          -%}
          {%- if settings[link_style_setting] == 'link'
            and settings[icon_setting] != 'none'
            and settings[icon_position_setting] == 'left'
          -%}
            </div>
          {%- endif -%}

          <span>
            {%- liquid
              # Article - Partners Template - Partner Reference
              if template.name == 'article' and template.suffix contains 'partners'
                if article.metafields.partners.name != blank
                  assign name = article.metafields.partners.name
                else
                  assign name = article.title
                endif

                echo settings[text_setting] | replace: '[[partner]]', name
              else
                # Standard Output
                echo settings[text_setting]
              endif
            -%}
          </span>

          {%- if settings[link_style_setting] == 'link'
            and settings[icon_setting] != 'none'
            and settings[icon_position_setting] == 'right'
          -%}
            <div
              class="min-w-[18px] rounded-full flex items-center justify-center min-h-[18px] aspect-square o-ctas__cta-icon"
            >
          {%- endif -%}
          {%- liquid
            if settings[icon_setting] != 'none' and settings[icon_position_setting] == 'right'
              render 'theme-icons' with settings[icon_setting], width: '1.5em', height: '1.5em'
            endif
          -%}
          {%- if settings[link_style_setting] == 'link'
            and settings[icon_setting] != 'none'
            and settings[icon_position_setting] == 'right'
          -%}
            </div>
          {%- endif -%}
        </a>
      {%- endif -%}
    {%- endfor -%}

    {{ external_button }}
  </div>
{%- endif -%}
