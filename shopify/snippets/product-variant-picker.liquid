{% comment %}
  Renders product variant-picker

  Accepts:
  - product: {Object} product object.
  - block: {Object} passing the block information.
  - update_url: {Boolean} whether or not to update url when changing variants. If false, the url isn't updated. Default: true (optional).

  Usage:
  {% render 'product-variant-picker', block: block, product: product %}
{% endcomment %}
{%- unless product.has_only_default_variant -%}
  {%- assign default_picker = block.settings.picker_type_default | default: 'button' -%}
  {%- assign swatch_picker_style = block.settings.picker_type_swatch | downcase | default: 'color,colour' -%}

  <variant-options
    id="variant-options-{{ section.id }}"
    class="variants js-variant-options"
    data-section="{{ section.id }}"
    data-url="{{ product.url }}"
    data-update-url="{{ update_url | default: true, allow_false: true }}"
    {{ block.shopify_attributes }}
    {%- if update_url- %}
      data-updateUrl="{{ update_url }}"
    {%- endif -%}
  >
    {%- for option in product.options_with_values -%}
      {%- liquid
        assign option_name = option.name | downcase
        assign option_picker_style = default_picker
        if swatch_picker_style contains option_name
          assign option_picker_style = 'swatch'
        endif

        assign product_guide = length_guide_page

        if option_name == 'colour'
          assign product_guide = colour_guide_page
        endif
      -%}
      <fieldset class="py-4 max-md:py-6 border-t border-grey-105">
        <div class="variants__block">
          <legend class="font-normal text-grey-0 tracking-standard text-sm">
            {{ option.name | replace: '_', ' ' }}
          </legend>

          {% if product_guide != blank %}
            <button
              is="modal-opener"
              modal="#PopupModal-{{ product_guide.handle }}"
              id="ProductPopup-{{ product_guide.handle }}"
              class="text-sm underline tracking-standard"
              type="button"
              aria-haspopup="dialog"
            >
              {{- 'products.product.size_guide' | t: name: option.name -}}
            </button>
          {% endif %}
          {%- if option_name == 'colour' -%}
            <div class="variants__selected-option js-selected-option">
              <span
                class="block w-[28px] h-[28px] rounded-full"
                data-swatch="{{ option.selected_value | handleize | replace: '-', '_' }}"
                {% if product.selected_variant.featured_image and settings.overwrite_swatch == false %}
                  style="--_bg: url({{ product.selected_variant.featured_image | image_url }});"
                {% endif %}
              ></span>
              <span class="text-md  text-grey-10" data-selected-option="{{ option.name }}">
                <span>{{- option.selected_value -}}</span>
              </span>

              <span class="variants__selected-option-icon flex ml-auto">
                {%- render 'theme-icons' with 'chevron-down', width: 16, height: 16, classes: 'text-grey-5' -%}
              </span>
            </div>
          {%- endif -%}

          <div class="variants__options js-variants-option" data-type="{{ option_picker_style }}">
            {%- render 'product-variant-options',
              product: product,
              option: option,
              picker_style: option_picker_style
            -%}
          </div>
        </div>
      </fieldset>
    {%- endfor -%}

    {% assign size_sibling_products = product.metafields.size.variants.value %}
    {% if size_sibling_products.count > 0 %}
      <fieldset class="py-4 max-md:py-6 border-t border-grey-105" data-ignore-option>
        <div class="variants__block">
          <legend class="font-normal text-grey-0 tracking-standard text-sm">Length</legend>

          {% if length_guide_page != blank %}
            <button
              is="modal-opener"
              modal="#PopupModal-{{ length_guide_page.handle }}"
              id="ProductPopup-{{ length_guide_page.handle }}"
              class="text-sm underline tracking-standard"
              type="button"
              aria-haspopup="dialog"
            >
              {{- 'products.product.size_guide' | t: name: 'Length' -}}
            </button>
          {% endif %}

          <div class="variants__options js-variants-option" data-type="{{ default_picker }}">
            {%- render 'product-variant-options',
              product: product,
              sibling_products: size_sibling_products,
              option: option,
              picker_style: option_picker_style
            -%}
          </div>
        </div>
      </fieldset>
    {% endif %}

    <script type="application/json">
      {{ product.variants | json }}
    </script>
  </variant-options>
{%- endunless -%}
