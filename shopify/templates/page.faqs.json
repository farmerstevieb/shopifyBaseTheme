        "faq_47GYiV": {
          "type": "faq",
          "settings": {
            "title": "What haircare products should I use on my hair extensions?",
            "body": "We only recommend the use of the Remi Cachet aftercare to maintain healthy hair extensions and prolong the longevity of the hair. We offer a variety of products in the range, including a shampoo, conditioner, miracle mist with added heat defence, and hair oil."
          }
        },
        "faq_dx6RHB": {
          "type": "faq",
          "settings": {
            "title": "Can I use heat on Remi Cachet hair extensions?",
            "body": "As Remi Cachet hair extensions are made with human hair, you can use your regular heat tools on them. We suggest no heat above 180° Celsius or 350° Fahrenheit to protect the structural integrity of the hair."
          }
        },
        "faq_KM3hHw": {
          "type": "faq",
          "settings": {
            "title": "Why are my Remi Cachet hair extensions fading?",
            "body": "Fading can happen to hair extensions, just as easily as it can to regular hair. Visit our aftercare guide to see how you can precent colour fading."
          }
        },
        "faq_nh6WWG": {
          "type": "faq",
          "settings": {
            "title": "What is discolouration and how do I prevent it?",
            "body": "Discolouration is caused by something external reacting with the hair extensions, and can typically be attributed to perfumes, lotions or creams on the skin that then come into contract with the hair. View our aftercare guide and blogs to view more information about discolouration prevention and cures."
          }
        }
      },
