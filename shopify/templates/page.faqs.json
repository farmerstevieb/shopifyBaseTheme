        "faq_EHgPUq": {
          "type": "faq",
          "settings": {
            "title": "What delivery options do you offer?",
            "body": "Click and Collect: Free, DPD - Express: £5.49, DPD - Before 12: £6.99, DPD - Saturday Delivery: £6.99, Royal Mail - Standard: £3.95, Royal Mail - Express: £7.49, and International Delivery from £12.99."
          }
        },
        "faq_iUxF8i": {
          "type": "faq",
          "settings": {
            "title": "What if I won’t be in to receive my order?",
            "body": "A signature is required for all deliveries unless you request it to be left in a safe place or with a neightbour. Please note that requesting it to be left in a safe place is at your own risk and liability."
          }
        },
        "faq_GwXKBf": {
          "type": "faq",
          "settings": {
            "title": "Will I be charged import duty?",
            "body": "If placing an order from outside the UK, any import duty and taxes will be the responsibility of the customer, as regulations vary in regards to the charges which apply from country to country. Please ensure you are happy with any potential tax or duty charges before proceeding with your order."
          }
        },
        "faq_wyTAXk": {
          "type": "faq",
          "settings": {
            "title": "Can I return a product?",
            "body": "Yes. Products can be returned for a refund within 60 days of purchase if they remain in their original, unopened packaging, with health and hygiene (security) tags intact. Refunds for unwanted products vary based on return timing: 100% within 30 days, 75% between 30-45 days, and 50% between 45-60 days. See our Returns page for more information."
          }
        },
        "faq_UxrLD7": {
          "type": "faq",
          "settings": {
            "title": "How long does a return take to process?",
            "body": "Returns are typically processed within 14 days from the day we receive your return in our warehouse. Please allow 3-5 working days from your refund notification for the funds to clear in your account."
          }
        }
      },
