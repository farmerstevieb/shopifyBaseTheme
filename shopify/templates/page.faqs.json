        "faq_HqbbEb": {
          "type": "faq",
          "settings": {
            "title": "What lengths of hair extensions do you offer?",
            "body": "Remi Cachet hair extensions come in a wide selection of lengths from 10” up to 30”. However, not all lengths are available in every applications method, colour, or range."
          }
        },
        "faq_MRYAgR": {
          "type": "faq",
          "settings": {
            "title": "Can I colour hair extensions?",
            "body": "We recommend keeping our hair extensions in their original colour. Deciding to colour or tone them falls entirely under your responsibility and risk. Remember, these extensions have already undergone chemical processing. Choosing to alter their colour could compromise their integrity and appearance. If a colour change is a must, consider dyeing the client’s natural hair to match the extensions before installation."
          }
        },
        "faq_J8cExN": {
          "type": "faq",
          "settings": {
            "title": "What does T and DD mean in your colour ranges?",
            "body": "When a colour starts with T it means that the colour is a root stretch colour. For example, if the colour is T5-9\/613 this means that it will be a 9\/613 mix with a root stretch of colour 5. Our root stretch length is around 2-3 inches depending on the overall length of the hair. When a colour starts with DD it means that the colour is a dip-dye colour. For example, if the colour is DD2\/6 this means that the top half of the hair is colour 2 followed by a colour 6 on the bottom half of the hair."
          }
        },
        "faq_TJaCdk": {
          "type": "faq",
          "settings": {
            "title": "What is the difference between the Super and Standard colour rings?",
            "body": "Our Super Ring features larger swatches, we recommend this ring for Salons and large workspaces. Our standard  colour ring has smaller swatches and is more suitable for those who may have a smaller workspace or are mobile."
          }
        },
        "faq_patUkt": {
          "type": "faq",
          "settings": {
            "title": "What is the difference between the Elegance, Deluxe and Luxury ranges?",
            "body": "Elegance is our most popular range and is double drawn Remy hair. Deluxe is our double drawn mid-ratio hair that is sourced from China. Luxury is naturally drawn Remy hair which tapers to a natural finish."
          }
        }
      },
