{% render 'theme_assets' with 'section-faqs.min.css' %}
{% render 'section-spacing-and-color' %}
{% liquid
  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip
%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- assign section_header = section.blocks | where: 'type', 'section_header' | first -%}
  {%- if section_header -%}
    {%- render 'object-content',
      block: section_header.settings,
      attributes: section_header.shopify_attributes,
      class: 'section-header mb-8',
      heading_font_weight: 'font-medium'
    -%}
  {%- endif -%}

  <div class="c-faqs">
    <ul class="c-faqs__items">
      {% assign faqBlocks = section.blocks | where: 'type', 'faq' %}
      {% for block in faqBlocks %}
        {% if block.settings.title != blank and block.settings.body != blank %}
          <li {{ block.shopify_attributes }}>
            {%- render 'object-accordion',
              title: block.settings.title,
              content: block.settings.body,
              class: 'c-faqs__item'
            -%}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
{% endif %}
