{%- assign text_class = 'text-sm font-semibold tracking-standard text-grey-10 uppercase' -%}

{%- if recommendations.performed and recommendations.products_count > 0 -%}
  <product-recommendations>
    <aside class="bg-[#F5F5F5] p-6">
      <h2 class="{{ text_class }} mb-6">
        {{ 'sections.cart.also_like' | t }}
      </h2>

      <ul role="list" class="space-y-4">
        {% assign cart_items = cart.items | map: 'product_id' %}
        {% assign count = 0 %}
        {%- for product in recommendations.products -%}
          {% liquid
            if count == 3
              break
            endif

            # Skip over products that are alread in basket
            if cart_items contains product.id
              continue
            endif

            assign count = count | plus: 1
          %}

          <li class="bg-white rounded-[3px] py-3">
            <div class="flex flex-wrap items-start justify-between gap-4">
              {% render 'object-image' with product.featured_image,
                width: 48,
                height: 62,
                aspect: '48 / 62',
                class: 'pl-3'
              %}

              <div class="flex flex-col flex-1 pr-3">
                <p class="{{ text_class }}">{{ product.title }}</p>
                <p class="text-sm font-semibold text-grey-10 uppercase">{{ product.price | money }}</p>
              </div>
              <hr class="o-hr w-full">

              {% form 'product', product, is: 'product-form', class: 'w-full text-center' %}
                <input
                  type="hidden"
                  name="id"
                  value="{{ product.selected_or_first_available_variant.id }}"
                >
                <button
                  class="button uppercase gap-x-1 hover:text-highlight text-sm tracking-standard font-semibold"
                  name="add"
                  type="submit"
                >
                  {% render 'theme-icons' with 'plus', width: 16, height: 16 %}
                  Quick Add
                </button>
              {% endform %}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </aside>
  </product-recommendations>
{%- endif -%}
