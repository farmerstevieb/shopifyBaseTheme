{%- render 'section-spacing-and-color' -%}

{% liquid
  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip
%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- paginate blog.articles by section.settings.limit -%}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-9 gap-y-12 lg:gap-y-14">
      {%- liquid
        assign is_first_section = true
        if section.index != blank and section.index > 1
          assign is_first_section = false
        endif
      -%}
      {%- for article in blog.articles -%}
        {% liquid
          capture hr
            if section.settings.layout == 'collage'
              cycle '', '', '', '<hr class="col-span-3 o-hr max-lg:hidden">'
            endif
          endcapture

          assign card_class = ''
          assign is_large = false
          if section.settings.layout == 'collage'
            assign modulo = forloop.index | modulo: 4
            if modulo == 0
              assign is_large = true

              capture card_class
                cycle '', 'lg:rtl-grid'
              endcapture
            endif
          endif
        %}

        {{ hr }}
        <div class="{% if is_large %} lg:col-span-3{% endif %}">
          {%- liquid
            assign should_preload = false
            if forloop.first and is_first_section
              assign should_preload = true
            endif
          -%}
          {%- render 'card-article',
            article: article,
            class: card_class,
            is_large: is_large,
            show_image: section.settings.show_image,
            show_date: section.settings.show_date,
            show_author: section.settings.show_author,
            show_tags: section.settings.show_tags,
            show_excerpt: true,
            preload: should_preload
          -%}
        </div>
        {{ hr }}
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="mt-9 md:mt-14">{%- render 'pagination', paginate: paginate, hide_text: true -%}</div>
    {%- endif -%}
  {%- endpaginate -%}
{% endif %}
