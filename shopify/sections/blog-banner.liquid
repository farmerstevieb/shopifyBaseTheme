{%- capture show_section -%}
  {{- section.settings.show_if -}}
{%- endcapture -%}
{% assign show_section = show_section | strip %}

{% liquid
capture display_section_snippet
render 'section_user-restriction'
endcapture
assign display_section = display_section_snippet | strip
%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- if show_section == blank or show_section == 'true' or show_section == true -%}
    {%- liquid
      render 'theme_assets' with 'section-text-media.min.css'
      render 'section-spacing', set_bg: false, set_padding: false

      assign is_full_width = false
      if section.settings.padding == 'full'
        assign is_full_width = true
      endif

      assign has_bg = true
      if section.settings.background_color == empty or section.settings.background_color == 'rgba(0,0,0,0)'
        assign has_bg = false
      endif
      assign media_aspect = '1108 / 519'
      assign aspect_mobile = ' 1/ 1'
      assign videoSrc = block.settings.video_file | default: block.settings.video_url
    -%}

    <div class="text-media text-media--{{ section.settings.padding }}{% if has_bg %} text-media--bg{% endif %} grid lg:grid-cols-6 items-center">
      <div class="text-media__text lg:col-span-2 text-media__text--wide {% if has_bg %} pt-9 pb-9{% endif %}">
        {%- render 'object-content', block: section.settings -%}
      </div>

      <div class="text-media__media lg:col-span-4">
        {%- liquid
          if videoSrc
            capture placeholder
              if section.settings.image
                render 'object-image' with section.settings.image, mobile_image: section.settings.image_mobile, class: 'o-video__image js-video-image'
              else
                echo 'image' | placeholder_svg_tag: 'o-video__image js-video-image'
              endif
            endcapture
            render 'object-video' with videoSrc, placeholder: placeholder, autoplay: section.settings.video_autoplay, muted: section.settings.video_muted, loop: true, fit: 'cover', aspect: media_aspect
          else
            if section.settings.image
              render 'object-image' with section.settings.image, mobile_image: section.settings.image_mobile, class: 'o-picture--fill', aspect: media_aspect, aspect_mobile: aspect_mobile
            else
              assign placeholder_class = 'o-picture--fill bg-grey-80" style="aspect-ratio:' | append: media_aspect
              echo 'image' | placeholder_svg_tag: placeholder_class
            endif
          endif
        -%}
      </div>
    </div>
  {%- endif -%}
{% endif %}
