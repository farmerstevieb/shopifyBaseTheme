{%- liquid
  render 'section-spacing-and-color', set_bg: false

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip

  assign have_bg_color = false
  if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)'
    assign have_bg_color = true
  endif

  assign background_height = section.settings.background_height
-%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {% style %}
    #shopify-section-{{ section.id }} {
        {%- if have_bg_color -%}
          position: relative;
        {%- endif -%}
      }
      {% if have_bg_color %}
        #shopify-section-{{ section.id }}::before {
          content: "";
          height: {{ background_height }}%;
          position: absolute;
          left: 0;
          right:0;
          top: 0;
          background: var(--bg);
          width: 100%;
          z-index: -1;
        }
      {% endif %}
  {% endstyle %}

  {%- assign section_header = section.blocks | where: 'type', 'section_header' | first -%}
  {%- if section_header -%}
    {%- render 'object-content',
      block: section_header.settings,
      attributes: section_header.shopify_attributes,
      class: 'section-header section-header--social mb-4 lg:mb-14'
    -%}
  {%- endif -%}
  <div class="grid lg:grid-cols-10 gap-[10px]">
    {%- liquid
      assign larger_card = section.blocks | where: 'type', 'larger_card' | first
    -%}
    {%- if larger_card -%}
      <div class="md:col-span-4 md:order-10">
        {%- if larger_card.settings.link -%}<a class="block" href="{{ larger_card.settings.link }}">{%- endif -%}
        {%- liquid
          assign image_class = 'o-img--' | append: larger_card.settings.image_fit
          assign aspect = '1 / 1'

          assign video_src = larger_card.settings.video_file | default: larger_card.settings.video_url
          if video_src
            assign play_video_on_mobile = true
            if larger_card.settings.image_mobile
              assign play_video_on_mobile = false
            endif
            capture placeholder
              render 'object-image' with larger_card.settings.image, mobile_image: larger_card.settings.image_mobile, preload: forloop.first, class: 'o-video__image js-video-image', img_class: image_class
            endcapture
            render 'object-video' with video_src, placeholder: placeholder, autoplay: larger_card.settings.video_autoplay, muted: larger_card.settings.video_muted, loop: true, fit: 'cover', class: 'card__media', play_on_mobile: play_video_on_mobile
          else
            if larger_card.settings.image
              render 'object-image' with larger_card.settings.image, mobile_image: larger_card.settings.image_mobile, aspect: aspect, aspect_mobile: '1 / 1', class: 'card__media', img_class: image_class
            endif
          endif
        -%}
        {%- if larger_card.settings.link -%}</a>{%- endif -%}
      </div>
    {%- endif -%}

    <ul class="grid grid-cols-12 gap-[10px] md:col-span-6">
      {%- assign cards = section.blocks | where: 'type', 'card' -%}
      {%- for block in cards -%}
        <li
          class="col-span-6 md:col-span-4 {{ block.settings.width }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.link -%}<a class="block" href="{{ block.settings.link }}">{%- endif -%}

          {%- liquid
            assign image_class = 'o-img--' | append: block.settings.image_fit
            assign aspect = '1 / 1'

            assign video_src = block.settings.video_file | default: block.settings.video_url
            if video_src
              assign play_video_on_mobile = true
              if block.settings.image_mobile
                assign play_video_on_mobile = false
              endif
              capture placeholder
                render 'object-image' with block.settings.image, mobile_image: block.settings.image_mobile, preload: forloop.first, class: 'o-video__image js-video-image', img_class: image_class
              endcapture
              render 'object-video' with video_src, placeholder: placeholder, autoplay: block.settings.video_autoplay, muted: block.settings.video_muted, loop: true, fit: 'cover', class: 'card__media', play_on_mobile: play_video_on_mobile
            else
              if block.settings.image
                render 'object-image' with block.settings.image, mobile_image: block.settings.image_mobile, aspect: aspect, aspect_mobile: '1 / 1', class: 'card__media', img_class: image_class
              endif
            endif
          -%}

          {%- if block.settings.link -%}</a>{%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>
{% endif %}
