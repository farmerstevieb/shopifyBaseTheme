{%- liquid
  render 'theme_assets' with 'section-content-cards.min.css'
  render 'section-spacing-and-color'

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip
%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- assign section_header = section.blocks | where: 'type', 'section_header' | first -%}
  {%- if section_header -%}
    {%- render 'object-content',
      block: section_header.settings,
      attributes: section_header.shopify_attributes,
      class: 'section-header mb-9'
    -%}
  {%- endif -%}

  <ul class="flex flex-wrap content-cards">
    {%- assign blocks = section.blocks | where: 'type', 'card' -%}
    {%- liquid
      assign is_first_section = true
      if section.index != blank and section.index > 1
        assign is_first_section = false
      endif
    -%}
    {%- for block in blocks -%}
      <li class="flex-grow {{ block.settings.width }}" {{ block.shopify_attributes }}>
        <div class="card">
          {%- liquid
            assign image_class = 'o-img--' | append: block.settings.image_fit
            case block.settings.width
              when 'col-span-8'
                assign aspect = '936 / 444'
              when 'col-span-6'
                assign aspect = '692 / 444'
              when 'col-span-4'
                assign aspect = '448 / 444'
              when 'col-span-3'
                assign aspect = '326 / 444'
            endcase

            assign video_src = block.settings.video_file | default: block.settings.video_url
            if video_src
              assign play_video_on_mobile = true
              if block.settings.image_mobile
                assign play_video_on_mobile = false
              endif
              assign should_preload = false
              if forloop.first and is_first_section
                assign should_preload = true
              endif
              capture placeholder
                render 'object-image' with block.settings.image, mobile_image: block.settings.image_mobile, preload: should_preload, class: 'o-video__image js-video-image', img_class: image_class
              endcapture
              render 'object-video' with video_src, placeholder: placeholder, autoplay: block.settings.video_autoplay, muted: block.settings.video_muted, loop: true, fit: 'cover', aspect: aspect, aspect_mobile: '1 / 1', play_on_mobile: play_video_on_mobile

            elsif block.settings.image
              render 'object-image' with block.settings.image, mobile_image: block.settings.image_mobile, aspect: aspect, aspect_mobile: '1 / 1', img_class: image_class
            else
              assign placeholder_class = 'bg-grey-80" style="aspect-ratio:var(--ar,' | append: aspect | append: ')'
              echo 'image' | placeholder_svg_tag: placeholder_class
            endif
          -%}

          {%- liquid
            assign heading_tag = 'h2'
            if section_header
              assign heading_tag = 'h3'
            endif
          -%}
          {%- render 'object-content',
            block: block.settings,
            attributes: block.shopify_attributes,
            class: 'card__content',
            heading_tag: heading_tag
          -%}
        </div>
      </li>
    {%- endfor -%}
  </ul>
{% endif %}
