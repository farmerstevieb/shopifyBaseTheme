{%- liquid
  render 'theme_assets' with 'section-content-cards.min.css'
  render 'section-spacing-and-color'
-%}

{% liquid
capture display_section_snippet
render 'section_user-restriction'
endcapture
assign display_section = display_section_snippet | strip
%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- assign section_header = section.blocks | where: 'type', 'section_header' | first -%}
  {%- if section_header -%}
    {%- render 'object-content',
      block: section_header.settings,
      attributes: section_header.shopify_attributes,
      class: 'section-header mb-9'
    -%}
  {%- endif -%}

  <juno-slider enabled loop showArrows>
    <div class="viewport" data-slider="viewport">
      <ul class="content-cards content-cards--carousel">
        {%- assign blocks = section.blocks | where: 'type', 'card' -%}
        {%- for block in blocks -%}
          <li class="flex-grow" {{ block.shopify_attributes }}>
            <div class="card">
              {%- liquid
                assign image_class = 'o-img--' | append: block.settings.image_fit

                assign video_src = block.settings.video_file | default: block.settings.video_url
                if video_src
                  assign play_video_on_mobile = true
                  if block.settings.image_mobile
                    assign play_video_on_mobile = false
                  endif
                  capture placeholder
                    render 'object-image' with block.settings.image, mobile_image: block.settings.image_mobile, preload: forloop.first, class: 'o-video__image js-video-image', img_class: image_class
                  endcapture
                  render 'object-video' with video_src, placeholder: placeholder, autoplay: block.settings.video_autoplay, muted: block.settings.video_muted, loop: true, fit: 'cover', aspect: '326 / 444', play_on_mobile: play_video_on_mobile
                else
                  render 'object-image' with block.settings.image, mobile_image: block.settings.image_mobile, aspect: '326 / 444', img_class: image_class
                endif
              -%}

              {%- liquid
                assign heading_tag = 'h2'
                if section.settings.heading
                  assign heading_tag = 'h3'
                endif
              -%}
              {%- render 'object-content',
                block: block.settings,
                attributes: block.shopify_attributes,
                class: 'card__content',
                heading_tag: heading_tag
              -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </juno-slider>
{% endif %}
