{%- liquid
  render 'theme_assets' with 'section-faqs.min.css'
  render 'section-spacing-and-color'

  assign faqBlocks = section.settings.blog

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip
-%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- paginate faqBlocks.articles by section.settings.limit -%}
    <div class="c-faqs">
      <h2 class="text-4xl font-medium tracking-wide text-center uppercase py-9 lg:py-14">{{ 'general.faqs' | t }}</h2>
      <ul class="c-faqs__items">
        {% for article in faqBlocks.articles %}
          {% assign content = article.excerpt | default: article.content %}
          <li {{ block.shopify_attributes }}>
            {%- render 'object-accordion',
              title: article.title,
              content: content,
              class: 'c-faqs__item',
              custom_class: 'c-faqs__blog'
            -%}
          </li>
        {% endfor %}
      </ul>
    </div>

    {%- if paginate.pages > 1 -%}
      <hr class="o-hr max-lg:my-9 mt-14 mb-9">
      {%- render 'pagination', paginate: paginate, show_text: false -%}
    {%- endif -%}
  {%- endpaginate -%}
{% endif %}
