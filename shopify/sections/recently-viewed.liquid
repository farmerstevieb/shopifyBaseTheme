{% liquid
  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip
%}
{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- render 'section-spacing-and-color' -%}

  <recently-viewed-products
    class="c-recently-viewed"
    data-section-id="{{ section.id }}"
    data-max-products="{{ section.settings.max_products }}"
    data-columns="{{ section.settings.columns }}"
    data-section-url="{{ routes.root_url }}?sections={{ section.id }}"
    data-aspect-ratio="{{ section.settings.aspect_ratio }}"
    aria-label="{{ section.settings.title | escape }}"
  >
    {%- comment -%}
      This element is initially hidden. The recently-viewed-products web component
      reads localStorage, fetches product data via Section Rendering API, then
      populates and reveals the section. If no recently-viewed products exist,
      the element stays hidden.
    {%- endcomment -%}
    <div class="c-recently-viewed__inner" hidden>
      {%- if section.settings.title != blank -%}
        <h2 class="c-recently-viewed__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      <ul
        class="c-recently-viewed__grid"
        data-columns="{{ section.settings.columns }}"
      ></ul>
    </div>

    {%- comment -%}
      SSR placeholder: when this section is fetched via Section Rendering API
      with a ?handles=... parameter, Liquid renders product cards server-side
      so the web component can extract and inject them without client-side product
      API calls as fallback.
    {%- endcomment -%}
    {%- if request.path contains 'sections' and section.settings.handles != blank -%}
      {%- assign handle_list = section.settings.handles | split: ',' -%}
      {%- assign render_count = 0 -%}
      {%- for raw_handle in handle_list -%}
        {%- assign item_handle = raw_handle | strip -%}
        {%- assign item = all_products[item_handle] -%}
        {%- if item != empty and render_count < section.settings.max_products -%}
          <template data-handle="{{ item_handle }}">
            {%- render 'card-product',
              product: item,
              aspect_ratio: section.settings.aspect_ratio,
              product_index: forloop.index
            -%}
          </template>
          {%- assign render_count = render_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </recently-viewed-products>
{% endif %}
