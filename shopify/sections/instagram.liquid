{% render 'section-spacing-and-color' %}
{% liquid
  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip
%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- assign section_header = section.blocks | where: 'type', 'section_header' | first -%}
  {%- assign section_ctas = section.blocks | where: 'type', 'ctas' | first -%}

  {%- if section_header -%}
    {%- render 'object-content',
      block: section_header.settings,
      attributes: section_header.shopify_attributes,
      class: 'section-header mb-[40px]',
      heading_font_weight: 'font-medium',
      heading_class: 'max-md:max-w-[200px]',
      text_class: 'max-md:max-w-[225px]'
    -%}
  {%- endif -%}

  {%- assign app_blocks = section.blocks | where: 'type', '@app' -%}

  {% for app in app_blocks %}
    {% render app %}
  {% else %}
    {%- assign blocks = section.blocks | where: 'type', 'image' -%}

    <div class="max-w-[1196px] mx-auto">
      <ecomplete-slider
        class="slider slider--instagram"
        enabled="(max-width: 768px)"
        loop
        align="center"
      >
        <div class="slider__viewport" data-slider="viewport">
          <ul class="flex slider__track">
            {%- for block in blocks -%}
              {%- liquid
                assign image = block.settings.image
                assign link = block.settings.link
              -%}
              <li class="slider__item">
                {%- if link != blank -%}<a class="block" href="{{ link }}">{%- endif -%}
                {% liquid
                  if image
                    render 'object-image' with image, class: 'card__media', aspect: '1 / 1'
                  else
                    echo 'image' | placeholder_svg_tag: 'bg-grey-80 aspect-[1/1]'
                  endif
                %}
                {%- if link != blank -%}</a>{%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </ecomplete-slider>
    </div>
  {% endfor %}

  {%- if section_ctas -%}
    <div class="flex justify-center mt-[40px] md:mt-12 mx-row">
      {%- render 'object-ctas',
        settings: section_ctas.settings,
        cta_sizes: section_ctas.settings.cta_sizes,
        cta_sizes_dsk: section_ctas.settings.cta_sizes_desktop,
        last_cta_index: 2,
        cta_custom_class: 'w-full md:flex md:justify-center'
      -%}
    </div>
  {%- endif -%}
{% endif %}
