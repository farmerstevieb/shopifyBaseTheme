{%- liquid
  render 'theme_assets' with 'section-main-stocklist.min.css'
  render 'section-spacing-and-color'

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip
-%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  <h1 class="pt-12 pb-6 text-3xl font-medium tracking-wide uppercase md:text-center leading-1 lg:pb-8 lg:pt-14 text-grey-0">
    {{- page.title -}}
  </h1>

  <div data-stockist-widget-tag="u5220">
    Loading store locator from <a href="https://stockist.co">Stockist store locator</a>...
  </div>
  <script>
    (function (s, t, o, c, k) {
      c = s.createElement(t);
      c.src = o;
      c.async = 1;
      k = s.getElementsByTagName(t)[0];
      k.parentNode.insertBefore(c, k);
    })(document, 'script', '//stockist.co/embed/v1/widget.min.js');
  </script>
{% endif %}
