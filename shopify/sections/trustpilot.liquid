{%- liquid
  render 'theme_assets' with 'section-trustpilot.min.css'
  render 'section-spacing-and-color'

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip
-%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- assign section_header = section.blocks | where: 'type', 'section_header' | first -%}
  {%- if section_header -%}
    {%- render 'object-content',
      block: section_header.settings,
      attributes: section_header.shopify_attributes,
      class: 'section-header mb-9'
    -%}
  {%- endif -%}

  {%- liquid
    # Build star filter array from individual checkboxes
    assign stars_array = ''
    if section.settings.star_1
      assign stars_array = stars_array | append: '1,'
    endif
    if section.settings.star_2
      assign stars_array = stars_array | append: '2,'
    endif
    if section.settings.star_3
      assign stars_array = stars_array | append: '3,'
    endif
    if section.settings.star_4
      assign stars_array = stars_array | append: '4,'
    endif
    if section.settings.star_5
      assign stars_array = stars_array | append: '5,'
    endif

    # Remove trailing comma
    assign stars_array = stars_array | remove_last: ','

    # If no stars selected, default to all
    if stars_array == ''
      assign stars_array = '1,2,3,4,5'
    endif

    # Slider
    capture slider_snippet
      render 'slider-settings', target: section
    endcapture

    assign slider_snippet = slider_snippet | split: ' ** '
    assign slider_settings = slider_snippet[0]
    assign slider_classes = slider_snippet[1]
    assign slider_variables = slider_snippet[2]
  -%}

  {{ slider_variables }}

  <trustpilot-reviews
    class="c-trustpilot__wrapper"
    data-api-key="{{ section.settings.api_key }}"
    data-business-unit-id="{{ section.settings.business_unit_id }}"
    data-star-filter="[{{ stars_array }}]"
    data-display-count="{{ section.settings.display_count }}"
    data-fetch-count="{{ section.settings.fetch_count }}"
    data-verified-only="{{ section.settings.verified_only }}"
    data-cache-expiration="{{ section.settings.cache_expiration }}"
    data-section-class="#shopify-section-{{ section.id }}"
  >
    <div class="trustpilot-carousel-wrapper">
      <juno-slider
        class="slider slider--trustpilot-carousel {{ slider_classes }}"
        {{ slider_settings }}
      >
        <div class="slider__viewport" data-slider="viewport">
          <ul class="slider__track flex" data-trustpilot-reviews>
            {% comment %} Placeholder cards to prevent layout shift {% endcomment %}
            {%- for i in (1..5) -%}
              <li class="slider__item">
                <div class="c-trustpilot__card c-trustpilot__card--skeleton">
                  <div class="c-trustpilot__card-header">
                    <div class="c-trustpilot__card-header--top">
                      <div class="c-trustpilot__card--skeleton-stars"></div>
                      <div class="c-trustpilot__card--skeleton-verified"></div>
                    </div>
                    <div class="c-trustpilot__card--skeleton-title"></div>
                  </div>
                  <div class="c-trustpilot__card-content">
                    <div class="c-trustpilot__card--skeleton-text"></div>
                    <div class="c-trustpilot__card--skeleton-text"></div>
                    <div class="c-trustpilot__card--skeleton-text short"></div>
                  </div>
                  <div class="c-trustpilot__card-footer">
                    <div class="c-trustpilot__card--skeleton-author"></div>
                  </div>
                </div>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </juno-slider>
    </div>
  </trustpilot-reviews>
{% endif %}
