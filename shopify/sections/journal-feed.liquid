{%- liquid
  render 'section-spacing-and-color'

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip

  assign blogBlock = section.blocks | where: 'type', 'blog' | map: 'settings' | first
  assign blogArticles = blogBlock.blog.articles | slice: 0, blogBlock.limit
  assign articleBlocks = section.blocks | where: 'type', 'article' | map: 'settings' | map: 'article'
  assign sectionArticles = articleBlocks | concat: blogArticles
  assign slider_enabled = section.settings.slider_enabled

  capture header_class
    case section.settings.text_color
      when 'dark'
        echo 'section-header mb-12 md:mb-14 stroke-grey-5'
      when 'light'
        echo 'section-header mb-12 md:mb-14 stroke-white'
    endcase
  endcapture
-%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- assign section_header = section.blocks | where: 'type', 'section_header' | first -%}
  {%- if section_header -%}
    {%- render 'object-content',
      block: section_header.settings,
      attributes: section_header.shopify_attributes,
      class: header_class,
      heading_font_weight: 'font-medium'
    -%}
  {%- endif -%}

  <ecomplete-slider
    class="c-journal-feed slider slider--journal-feed slider--full {% if slider_enabled == 'false' %}slider--disable{% endif%}"
    enabled="{{ slider_enabled }}"
    loop
    showArrows
    style="--total-column: {{ section.settings.total_column}}"
  >
    <div class="slider__viewport" data-slider="viewport">
      <ul
        class="slider__track md:flex"
      >
        {%- for article in sectionArticles -%}
          <li class="slider__item">
            <div class="card card--article">
              <a class="absolute inset-0 z-10 cursor-pointer" href="{{article.url}}"></a>

              {% liquid
                if article.image
                  render 'object-image' with article.image, class: 'card__media', aspect: '458 / 444'
                else
                  echo 'image' | placeholder_svg_tag: 'bg-grey-80 aspect-[300/190] sm:aspect-[702/444]'
                endif
              %}

              {%- liquid
                assign heading_tag = 'h2'
                if section_header
                  assign heading_tag = 'h3'
                endif

                assign text = article.excerpt | default: article.content | strip_html | truncatewords: 30
              -%}
              {%-
                render 'object-content',
                class: 'card__content relative z-20',
                color: section.settings.text_color,
                heading: article.title,
                heading_size: 'lg',
                heading_tag: heading_tag,
                heading_class: 'line-clamp-1',
                content_class: 'gap-3',
                cta_custom_class: 'mt-auto',
                content_gap: 4,
                content_gap_desktop: 4,
                text: text,
                text_size: 'md',
                text_class: 'text-grey-25',
                block: section.settings,
                cta_link: article.url;
              -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </ecomplete-slider>
{% endif %}
