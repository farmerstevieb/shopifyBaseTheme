{% liquid
  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip
%}
{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- liquid
    assign bg_color = section.settings.background_color
    assign text_color_setting = section.settings.text_color
  -%}
  <style>
    #shopify-section-{{ section.id }} .c-countdown-timer {
      {%- if bg_color != blank and bg_color != 'rgba(0,0,0,0)' -%}
        background-color: {{ bg_color }};
      {%- endif -%}
      {%- if text_color_setting != blank and text_color_setting != 'rgba(0,0,0,0)' -%}
        color: {{ text_color_setting }};
      {%- endif -%}
    }
    #shopify-section-{{ section.id }} .c-countdown-timer__unit-value,
    #shopify-section-{{ section.id }} .c-countdown-timer__unit-label {
      {%- if text_color_setting != blank and text_color_setting != 'rgba(0,0,0,0)' -%}
        color: {{ text_color_setting }};
      {%- endif -%}
    }
    #shopify-section-{{ section.id }} .c-countdown-timer__box {
      {%- if text_color_setting != blank and text_color_setting != 'rgba(0,0,0,0)' -%}
        border-color: {{ text_color_setting | color_modify: 'alpha', 0.25 }};
      {%- endif -%}
    }
  </style>

  <countdown-timer
    class="c-countdown-timer"
    data-target-date="{{ section.settings.target_date | escape }}"
    data-show-after-expired="{{ section.settings.show_after_expired }}"
    data-expired-text="{{ 'sections.countdown_timer.offer_ended' | t }}"
  >
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="c-countdown-timer__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="c-countdown-timer__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="c-countdown-timer__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="c-countdown-timer__clock" aria-live="polite" aria-atomic="true">
      <div class="c-countdown-timer__box" data-unit="days">
        <span class="c-countdown-timer__unit-value" data-value="days">00</span>
        <span class="c-countdown-timer__unit-label">{{ 'sections.countdown_timer.days' | t }}</span>
      </div>
      <div class="c-countdown-timer__separator" aria-hidden="true">:</div>
      <div class="c-countdown-timer__box" data-unit="hours">
        <span class="c-countdown-timer__unit-value" data-value="hours">00</span>
        <span class="c-countdown-timer__unit-label">{{ 'sections.countdown_timer.hours' | t }}</span>
      </div>
      <div class="c-countdown-timer__separator" aria-hidden="true">:</div>
      <div class="c-countdown-timer__box" data-unit="minutes">
        <span class="c-countdown-timer__unit-value" data-value="minutes">00</span>
        <span class="c-countdown-timer__unit-label">{{ 'sections.countdown_timer.minutes' | t }}</span>
      </div>
      <div class="c-countdown-timer__separator" aria-hidden="true">:</div>
      <div class="c-countdown-timer__box" data-unit="seconds">
        <span class="c-countdown-timer__unit-value" data-value="seconds">00</span>
        <span class="c-countdown-timer__unit-label">{{ 'sections.countdown_timer.seconds' | t }}</span>
      </div>
    </div>

    {%- if section.settings.cta_text != blank -%}
      <div class="c-countdown-timer__cta">
        <a
          href="{{ section.settings.cta_link }}"
          class="c-countdown-timer__cta-btn btn btn--primary"
        >
          {{ section.settings.cta_text | escape }}
        </a>
      </div>
    {%- endif -%}

    <div class="c-countdown-timer__expired-message" hidden>
      {{ 'sections.countdown_timer.offer_ended' | t }}
    </div>
  </countdown-timer>
{% endif %}
