{%- liquid
  render 'section-spacing-and-color'

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip

  # Section Header
  assign default_header_classes = 'section-header '

  # Prevents header from hugging left/right of the screen when the container is set to full.
  if section.settings.padding == 'full'
    assign default_header_classes = default_header_classes | append: 'px-row '
  endif

  assign header_classes = header_classes | default: 'mb-9' | prepend: default_header_classes
  assign section_header = section.blocks | where: 'type', 'section_header' | first

  if section_header
    render 'object-content', block: section_header.settings, attributes: section_header.shopify_attributes, class: header_classes
  endif

  # Image Aspect Ratios
  capture media_aspect
    render 'section-aspect-ratios', section: section
  endcapture

  # Grid Spacing, Structure
  render 'section-grid', section: section
-%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- paginate collections by section.settings.pagination_amount -%}
    <div class="pt-2 md:pt-4 lg:pt-8 js-paginatable">
      {%- if collections.size != 0 -%}
        {% # Collections List %}
        <ul class="grid section-grid js-paginatable-list">
          {%- for collection in collections -%}
            <li class="relative group js-paginatable-item">
              <a
                class="absolute inset-0 w-full h-full cursor-pointer z-1"
                href="{{ collection.url }}"
              ></a>

              <div
                class="relative flex transition-all duration-500 ease-ease group-hover:shadow-3 group-hover:scale-card before:absolute before:bg-white before:inset-0 before:transition-opacity before:duration-500 before:ease-ease before:z-1 before:opacity-0 group-hover:before:opacity-20"
                style="aspect-ratio: {{ media_aspect }};"
              >
                {%- liquid
                  if collection.image != blank
                    render 'object-image' with collection.image, preload: true, img_class: 'o-img--fill', class: 'origin-center transition-transform o-picture--fill'
                  else
                    assign placeholder_class = 'bg-grey-80 w-full origin-center pointer-events-none" style="aspect-ratio:' | append: media_aspect
                    echo 'image' | placeholder_svg_tag: placeholder_class
                  endif
                -%}
              </div>

              <p class="flex items-center py-4">
                {{- collection.title -}}

                {%- render 'theme-icons' with 'arrow-right',
                  width: 18,
                  height: 18,
                  class: 'ml-2 group-hover:ml-3 transition-all duration-500 ease-out stroke-current'
                -%}
              </p>
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        {% # No Collections %}
        <h2 class="font-heading">
          {{- 'templates.list_collections.no_collections' | t -}}
        </h2>
      {%- endif -%}

      {%- liquid
        # Converts string to integer
        assign pagination_visibility = settings.pagination_visibility | plus: 0

        if paginate.pages > pagination_visibility
          case section.settings.pagination_style
            when 'text'
              render 'pagination-text', paginate: paginate
            when 'dynamic'
              render 'pagination-dynamic', paginate: paginate
          endcase
        endif
      -%}
    </div>
  {%- endpaginate -%}
{% endif %}
