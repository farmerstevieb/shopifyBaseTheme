{%- liquid
  render 'theme_assets' with 'section-banner-grid.min.css'
  render 'section-spacing-and-color'

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip
-%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {%- assign section_header = section.blocks | where: 'type', 'section_header' | first -%}
  {%- if section_header -%}
    {%- render 'object-content',
      block: section_header.settings,
      attributes: section_header.shopify_attributes,
      class: 'section-header mb-9 lg:mb-14'
    -%}
  {%- endif -%}

  <ul class="flex flex-wrap banner-grid md:grid md:grid-cols-12">
    {%- assign blocks = section.blocks | where: 'type', 'card' -%}
    {%- liquid
      assign is_first_section = true
      if section.index != blank and section.index > 1
        assign is_first_section = false
      endif
    -%}
    {%- for block in blocks -%}
      <li class="banner-grid__item {{ block.settings.width }}" {{ block.shopify_attributes }}>
        <div class="card card--banner-grid {% if section.settings.content_position != blank %} card--banner-grid-position {% endif %}">
          {%- liquid
            assign image_class = 'o-img--' | append: block.settings.image_fit
            case block.settings.width
              when 'col-span-8'
                assign aspect = '936 / 444'
              when 'col-span-6'
                assign aspect = '692 / 444'
              when 'col-span-4'
                assign aspect = '448 / 444'
              when 'col-span-3'
                assign aspect = '326 / 444'
            endcase
            if section.settings.media_ratio == 'from_media'
              assign aspect = null
            endif

            assign video_src = block.settings.video_file | default: block.settings.video_url
            if video_src
              assign play_video_on_mobile = true
              if block.settings.image_mobile
                assign play_video_on_mobile = false
              endif
              assign should_preload = false
              if forloop.first and is_first_section
                assign should_preload = true
              endif
              capture placeholder
                render 'object-image' with block.settings.image, mobile_image: block.settings.image_mobile, preload: should_preload, class: 'o-video__image js-video-image', img_class: image_class
              endcapture
              render 'object-video' with video_src, placeholder: placeholder, autoplay: block.settings.video_autoplay, muted: block.settings.video_muted, loop: true, fit: 'cover', class: 'card__media', play_on_mobile: play_video_on_mobile
            endif
          -%}
          {%- if video_src == blank and block.settings.image -%}
            {% if block.settings.cta_1_link %}
              <a href="{{ block.settings.cta_1_link }}">
            {% endif %}
            {%- render 'object-image' with block.settings.image,
              mobile_image: block.settings.image_mobile,
              aspect: aspect,
              aspect_mobile: '1 / 1',
              class: 'card__media',
              img_class: image_class
            -%}
            {% if block.settings.cta_1_link %}
              </a>
            {% endif %}
          {%- endif -%}
          {%- liquid
            assign heading_tag = 'h2'
            if section_header
              assign heading_tag = 'h3'
            endif
          -%}
          {%- render 'object-content',
            block: block.settings,
            attributes: block.shopify_attributes,
            class: 'card__content',
            heading_class: 'normal-case',
            heading_font_weight: heading_font_weight,
            heading_tag: heading_tag,
            ctas_sizes: 'full'
          -%}
        </div>
      </li>
    {%- endfor -%}
  </ul>
{% endif %}
