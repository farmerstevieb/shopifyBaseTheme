{%- liquid
  render 'theme_assets' with 'section-text-media.min.css'
  render 'section-spacing-and-color', set_bg: false, set_padding: false

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip

  assign is_full_width = false
  if section.settings.padding == 'full'
    assign is_full_width = true
  endif

  assign has_bg = true
  if section.settings.background_color == empty or section.settings.background_color == 'rgba(0,0,0,0)'
    assign has_bg = false
  endif

  assign aspect = '1108 / 364'

  if section.settings.show_collection_image != true
    assign padding_class = 'no-banner lg:col-span-8'
    assign grid_class = 'lg:grid-cols-[var(--row-space)_repeat(8,minmax(0,1fr))_var(--row-space)]'
  else
    assign padding_class = 'lg:col-span-4'
    assign grid_class = 'lg:grid-cols-[var(--row-space)_repeat(8,minmax(0,1fr))_var(--row-space)]'
  endif
-%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  <div class="text-media text-media--{{ section.settings.padding }}{% if has_bg %} text-media--bg{% endif %} {{ grid_class }} grid items-center">
    <div class="text-media__text {{ padding_class }} {% if has_bg %} pt-9 pb-9{% endif %} justify-start">
      {% liquid
        if section.settings.show_collection_description
          assign text = collection.description
        endif
      %}
      {% capture heading %}
      {{- collection.title | escape -}}
    {% endcapture %}
      {%- liquid
        assign content_width_value = section.settings.content_width
      -%}
      {%- render 'object-content',
        heading: heading,
        heading_tag: 'h1',
        heading_size: '4xl',
        text: text,
        content_width: content_width_value,
        text_size: 'md',
        position: 'start',
        position_desktop: 'start',
        text_size_desktop: 'base',
        color: section.settings.text_color,
        truncate: section.settings.enable_read_more,
        max_lines: section.settings.max_lines,
        trigger_more_text: 'Read more',
        trigger_less_text: 'Read less',
        description_spacing: section.settings.description_spacing,
        description_spacing_desktop: section.settings.description_spacing_desktop
      %}
    </div>

    {% if section.settings.show_collection_image %}
      <div class="text-media__media max-lg:hidden lg:col-span-6">
        {%- liquid
          assign aspect = section.settings.image_height | replace: ' ', ''
          assign has_custom_aspect = false
          if aspect != blank
            assign aspect_parts = aspect | split: '/'
            if aspect_parts.size == 2
              assign aspect = aspect_parts[0] | append: ' / ' | append: aspect_parts[1]
              assign has_custom_aspect = true
            endif
          endif

          assign image_class = 'max-h-[600px] min-h-full'
          unless has_custom_aspect
            assign image_class = image_class | prepend: 'o-picture--fill '
          endunless

          if collection.image
            render 'object-image' with collection.image, class: image_class, aspect: aspect, aspect_mobile: '414/256'
          else
            assign placeholder_class = 'bg-grey-80" style="aspect-ratio:' | append: aspect
            unless has_custom_aspect
              assign placeholder_class = 'o-picture--fill ' | append: placeholder_class
            endunless
            echo 'image' | placeholder_svg_tag: placeholder_class
          endif
        -%}
      </div>
    {% endif %}
  </div>
{% endif %}
