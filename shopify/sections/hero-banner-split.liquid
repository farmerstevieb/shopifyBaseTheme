{%- liquid
  render 'theme_assets' with 'section-hero.min.css'
  render 'section-spacing-and-color'

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip

  # Spacing Class (Required)
  capture section_padding_class
    echo 'section-spacing--' | append: section.settings.padding
  endcapture

  # Slider
  capture slider_snippet
    render 'slider-settings', target: section
  endcapture

  assign slider_snippet = slider_snippet | split: ' ** '

  assign slider_settings = slider_snippet[0]
  assign slider_classes = slider_snippet[1]
  assign slider_variables = slider_snippet[2]

  assign aspect_ratio_dsk = '1120 / 672'
  assign aspect_ratio_mob = '414 / 394'
  assign banner_ratio = section.settings.banner_ratio
  assign banner_ratio_dsk = section.settings.banner_ratio_dsk

  if banner_ratio != ''
    assign aspect_ratio_mob = banner_ratio | replace: ' ', ''
  endif

  if banner_ratio_dsk != ''
    assign aspect_ratio_dsk = banner_ratio_dsk | replace: ' ', ''
  endif
-%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  {{ slider_variables }}

  <juno-slider
    class="slider slider--slideshow {{ section_padding_class }} {{ slider_classes }}"
    {{ slider_settings }}
  >
    <div
      class="slider__viewport slider__hero-split"
      data-slider="viewport"
    >
      <ul class="slider__track">
        {%- for block in section.blocks -%}
          <li
            class="hero hero--split"
            style="--overlay:{{ block.settings.overlay | default: 'none' }}"
            {{ block.shopify_attributes }}
          >
            <div class="hero__media js-hero-media">
              {%- liquid
                assign media_class = ' o-picture--fill'
                assign image_class = 'o-img--' | append: block.settings.image_fit
                assign video_src = block.settings.video_file | default: block.settings.video_url

                if video_src
                  assign play_video_on_mobile = true

                  if block.settings.image_mobile
                    assign play_video_on_mobile = false
                  endif

                  capture placeholder
                    render 'object-image' with block.settings.image, mobile_image: block.settings.image_mobile, preload: forloop.first, class: 'o-video__image js-video-image', img_class: image_class, visible_placeholder: false
                  endcapture

                  render 'object-video' with video_src, placeholder: placeholder, autoplay: block.settings.video_autoplay, muted: block.settings.video_muted, loop: true, fit: 'cover', class: media_class, play_on_mobile: play_video_on_mobile, aspect: aspect_ratio_dsk, aspect_mobile: aspect_ratio_mob
                else
                  render 'object-image' with block.settings.image, mobile_image: block.settings.image_mobile, preload: forloop.first, class: media_class, img_class: image_class, visible_placeholder: false, aspect: aspect_ratio_dsk, aspect_mobile: aspect_ratio_mob
                endif

                # Text Classes
                capture text_classes
                  echo 'hero__text'

                  # Mobile Media Position
                  if block.settings.mobile_media_position == 'text_first'
                    echo ' max-md:row-start-1'
                  else
                    echo ' max-md:row-start-2'
                  endif
                endcapture

                capture usps
                  render 'object-usps', target: block, amount_of_usps: 4
                endcapture
              -%}

              {%- if block.settings.bg_content and block.settings.bg_content != '' -%}
                {%- style -%}
                  #shopify-section-{{ section.id }} .hero__text[data-block-id="{{ block.id }}"] {
                    background-color: {{ block.settings.bg_content }};
                  }
                {%- endstyle -%}
              {%- endif -%}
              {%- unless section.settings['slider_dots-'] %}
                {%- render 'shop-the-look',
                  products: block.settings.stl_products,
                  position: block.settings.stl_position,
                  title: block.settings.stl_title
                -%}
              {% endunless %}
            </div>

            {%- render 'object-content',
              block: block.settings,
              attributes: block.shopify_attributes,
              class: text_classes,
              external_content_above_ctas: usps,
              data_block_id: block.id
            -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </juno-slider>
{% endif %}
