{%- liquid
  render 'section-spacing-and-color', width: 702

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip
-%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  <h1 class="py-12 text-3xl font-medium capitalise md:text-center leading-1 tracking-0 lg:py-14 text-grey-0">
    {{- page.title -}}
  </h1>

  <hr class="o-hr mb-9" role="presentation">

  <div class="rte rte--page">
    {{ page.content }}
  </div>
{% endif %}
