{%- liquid
  render 'theme_assets' with 'section-article.min.css'
  render 'section-spacing', set_bg: false

  capture display_section_snippet
    render 'section_user-restriction'
  endcapture
  assign display_section = display_section_snippet | strip

  assign article_image = article.image
  assign article_mob_image = article.image
  assign articles_desc = article.metafields.custom.description
  if article.metafields.custom.image_banner != blank
    assign article_image = article.metafields.custom.image_banner
  endif
-%}

{% if display_section == 'false' %}
  <style>
    #shopify-section-{{section.id}} {
      padding: 0 !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

{% if display_section == 'true' %}
  <div class="flex flex-col gap-12 md:gap-14">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          <div class="" {{ block.shopify_attributes }}>
            {% render block %}
          </div>

        {%- when 'featured_image' -%}
          {%- if article.image -%}
            <div class="" {{ block.shopify_attributes }}>
              {%- render 'object-image' with article_image,
                mobile_image: article_mob_image,
                aspect: '1441 / 672',
                aspect_mobile: '1 / 1',
                preload: true
              -%}
            </div>
          {%- endif -%}

        {%- when 'title' -%}
          <div class="mt-12 md:mt-14" {{ block.shopify_attributes }}>
            <header class="text-center">
              <span class="block mb-6 font-semibold tracking-wide uppercase text-md text-grey-0">
                {% assign published_at = article.published_at | date: '%d %b %Y' %}
                {{ 'templates.article.author_and_published' | t: author: article.author, published_at: published_at }}
              </span>

              <h1 class="text-3xl font-medium tracking-wide leading-1 lg:text-4xl">{{ article.title }}</h1>
              {%- if section.settings.show_tags -%}
                <ul class="flex flex-wrap justify-center gap-2 ">
                  {% for tag in article.tags %}
                    <li class="py-[1px] px-[5px] text-sm bg-border-light rounded-1 list-none">{{ tag }}</li>
                  {% endfor %}
                </ul>
              {%- endif -%}
              {%- if articles_desc != blank -%}
                <p class="mt-4 text-md text-grey-25">{{ articles_desc }}</p>
              {%- endif -%}
            </header>
          </div>

        {%- when 'content' -%}
          <div
            class="lg:flex lg:flex-col lg:gap-[40px]"
            {{ block.shopify_attributes }}
          >
            <div class="rte rte--article">
              {{ article.content }}
            </div>
          </div>
        {%- when 'social' -%}
          {%- liquid
            assign share_url = request.origin | append: article.url
            assign button_class = 'flex items-center justify-center border p-[7px]'
          -%}
          <div class="max-w-[900px] m-auto p-6">
            <div class="flex gap-4">
              <a
                class="{{ button_class }}"
                target="_blank"
                href="https://twitter.com/intent/tweet?url={{ share_url }}"
                aria-label="Share on Twitter"
              >
                <img
                  src="{{ 'twitter.png' | asset_url }}"
                  loading="lazy"
                  width="14"
                  height="14"
                >
              </a>
              <a
                class="{{ button_class }}"
                target="_blank"
                href="https://www.facebook.com/sharer/sharer.php?u={{ share_url }}"
                aria-label="Share on facebook"
              >
                <img
                  src="{{ 'facebook.png' | asset_url }}"
                  loading="lazy"
                  width="14"
                  height="14"
                >
              </a>

              <a
                class="{{ button_class }}"
                target="_blank"
                href="https://twitter.com/intent/tweet?url={{ share_url }}"
                aria-label="Share on Twitter"
              >
                <img
                  src="{{ 'instagram.png' | asset_url }}"
                  loading="lazy"
                  width="14"
                  height="14"
                >
              </a>
              <button
                is="share-button"
                class="{{ button_class }}"
                href="{{ share_url }}"
                aria-label="Share link"
              >
                <img
                  src="{{ 'link.png' | asset_url }}"
                  loading="lazy"
                  width="14"
                  height="14"
                >
              </button>
            </div>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
{% endif %}
