<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- liquid
      # theme-check-disable
      echo content_for_header
      # theme-check-enable

      render 'theme_head'
      render 'theme-seo'

      echo settings.head_scripts

      # Template Classes
      capture template_class
        assign template_name = template.name

        if template.suffix != blank
          assign template_name = template_name | append: '-' | append: template.suffix
        endif

        echo template_name
      endcapture
    -%}
  </head>

  <body class="{{ template_class }}" itemscope itemtype="http://schema.org/WebPage">
    <a class="sr-only" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>

    <main id="MainContent" tabindex="-1">
      {{ content_for_layout }}

      <div
        class="bg-overlay js-main-overlay pointer-events-none fixed inset-header z-1 opacity-0 transition-opacity duration-700"
      ></div>
    </main>

    {%- liquid
      section 'main-modal'
    -%}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
    </ul>

    {{ settings.body_scripts }}
  </body>
</html>
